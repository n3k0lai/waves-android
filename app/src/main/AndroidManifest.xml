<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Emote loading from emotes.comfy.sh -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Widget hosting -->
    <uses-permission android:name="android.permission.BIND_APPWIDGET" />
    <!-- Notifications expand (gesture) -->
    <uses-permission android:name="android.permission.EXPAND_STATUS_BAR" />

    <application
        android:name=".WavesApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Waves">

        <!-- Main Settings Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Waves">

            <!-- App launcher -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- ADW Launcher (base standard — Niagara, Smart, Action, broad compat) -->
            <intent-filter>
                <action android:name="org.adw.launcher.THEMES" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Nova Launcher -->
            <intent-filter>
                <action android:name="com.novalauncher.THEME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.teslacoilsw.launcher.THEME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Action Launcher -->
            <intent-filter>
                <action android:name="com.actionlauncher.playstore.theme" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Smart Launcher (with Material You support) -->
            <intent-filter>
                <action android:name="org.adw.launcher.THEMES" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="org.icontheme.CHANGES_WITH_MATERIAL_YOU_COLORS" />
                <category android:name="org.icontheme.FALLBACK_TO_THEMED_ICON" />
            </intent-filter>

            <!-- Lawnchair (themed icons) -->
            <intent-filter>
                <action android:name="app.lawnchair.icons.THEMED_ICON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Apex Launcher -->
            <intent-filter>
                <action android:name="com.anddoes.launcher.THEME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- GO Launcher -->
            <intent-filter>
                <action android:name="com.gau.go.launcherex.theme" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Launcher Home Screen -->
        <activity
            android:name=".launcher.LauncherActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:stateNotNeeded="true"
            android:clearTaskOnLaunch="true"
            android:resumeWhilePausing="true"
            android:theme="@style/Theme.Waves.Launcher"
            android:configChanges="keyboard|keyboardHidden|mcc|mnc|navigation|orientation|screenLayout|screenSize|smallestScreenSize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Live Wallpaper Service -->
        <service
            android:name=".wallpaper.WavesWallpaperService"
            android:exported="true"
            android:label="@string/wallpaper_name"
            android:permission="android.permission.BIND_WALLPAPER">

            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>

            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/wallpaper" />
        </service>

        <!-- Quick Settings Tile: toggle wallpaper animation -->
        <service
            android:name=".tile.WavesAnimationTile"
            android:exported="true"
            android:icon="@drawable/ic_tile_waves"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">

            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Keyboard IME Service -->
        <service
            android:name=".keyboard.WavesKeyboardService"
            android:exported="true"
            android:label="@string/keyboard_label"
            android:permission="android.permission.BIND_INPUT_METHOD">

            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>

            <meta-data
                android:name="android.view.im"
                android:resource="@xml/keyboard_method" />
        </service>

        <!-- Accessibility Service (for double-tap-to-lock) -->
        <service
            android:name=".launcher.gesture.SleepService"
            android:exported="true"
            android:label="Waves Screen Lock"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">

            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service" />
        </service>

        <!-- Notification Listener (for badge counts) -->
        <service
            android:name=".launcher.home.NotificationBadgeService"
            android:exported="true"
            android:label="Waves Badge Service"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">

            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Screenfetch Widget -->
        <receiver
            android:name=".widget.WavesWidgetProvider"
            android:exported="true"
            android:label="@string/widget_name">

            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="sh.comfy.waves.WIDGET_REFRESH" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

    </application>

</manifest>
